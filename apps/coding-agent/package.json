{
  "name": "@openkrow/coding-agent",
  "version": "0.1.0",
  "description": "Interactive coding agent CLI - open-source terminal AI assistant",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openkrow": "./dist/cli.js",
    "krow": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openkrow/llm": "*",
    "@openkrow/agent": "*",
    "@openkrow/tui": "*",
    "commander": "^13.1.0",
    "glob": "^11.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "^5.7.0"
  }
}
