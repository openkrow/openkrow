{
  "name": "@openkrow/app",
  "version": "0.1.0",
  "description": "OpenKrow - Open-source AI assistant. Assembles all packages and exposes the HTTP API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "bun run dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openkrow/agent": "*",
    "@openkrow/config": "*",
    "@openkrow/workspace": "*",
    "@openkrow/database": "*"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
