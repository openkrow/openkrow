{
  "name": "@openkrow/workspace",
  "version": "0.1.0",
  "description": "Workspace management for OpenKrow — folder structure, context, jobs, templates, scripts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bun-types": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
