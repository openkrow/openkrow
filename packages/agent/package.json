{
  "name": "@openkrow/agent",
  "version": "0.1.0",
  "description": "Agent runtime with tool calling and state management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp -r context/prompt dist/context/prompt && cp tools/*.txt dist/tools/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "@openkrow/database": "*",
    "@openkrow/skill": "*",
    "@openkrow/workspace": "*",
    "@mariozechner/pi-ai": "^0.70.5",
    "bun-types": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
