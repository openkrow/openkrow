{
  "name": "krow",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bun run css && electrobun dev",
    "dev": "concurrently \"bun run css:watch\" \"electrobun dev --watch\"",
    "css": "bunx @tailwindcss/cli -i mainview/index.css -o mainview/styles.css",
    "css:watch": "bunx @tailwindcss/cli -i mainview/index.css -o mainview/styles.css --watch",
    "build": "bun run css && electrobun build",
    "build:prod": "bun run css && electrobun build --env stable",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.39",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electrobun": "^1.18.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.6.2"
  }
}
